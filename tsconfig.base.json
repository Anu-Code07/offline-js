{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "@offlinejs/client": ["./packages/offlinejs/src/index.ts"],
      "@offlinejs/core": ["./packages/core/src/index.ts"],
      "@offlinejs/auth": ["./packages/auth/src/index.ts"],
      "@offlinejs/benchmarks": ["./packages/benchmarks/src/index.ts"],
      "@offlinejs/conflicts": ["./packages/conflicts/src/index.ts"],
      "@offlinejs/broadcast": ["./packages/coordination/src/index.ts"],
      "@offlinejs/devtools": ["./packages/devtools/src/index.ts"],
      "@offlinejs/devtools-ui": ["./packages/devtools-ui/src/index.ts"],
      "@offlinejs/encryption": ["./packages/encryption/src/index.ts"],
      "@offlinejs/network": ["./packages/network/src/index.ts"],
      "@offlinejs/next": ["./packages/next/src/index.ts"],
      "@offlinejs/queue": ["./packages/queue/src/index.ts"],
      "@offlinejs/react": ["./packages/react/src/index.ts"],
      "@offlinejs/sw": ["./packages/service-worker/src/index.ts"],
      "@offlinejs/storage-indexeddb": ["./packages/storage-indexeddb/src/index.ts"],
      "@offlinejs/storage-memory": ["./packages/storage-memory/src/index.ts"],
      "@offlinejs/storage-opfs": ["./packages/storage-opfs/src/index.ts"],
      "@offlinejs/storage-sqlite": ["./packages/storage-sqlite/src/index.ts"],
      "@offlinejs/sync": ["./packages/sync/src/index.ts"],
      "@offlinejs/sync-protocol": ["./packages/sync-protocol/src/index.ts"],
      "@offlinejs/types": ["./packages/types/src/index.ts"],
      "@offlinejs/utils": ["./packages/utils/src/index.ts"],
      "@offlinejs/validation": ["./packages/validation/src/index.ts"],
      "@offlinejs/worker-sync": ["./packages/worker-sync/src/index.ts"]
    }
  }
}
