{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo \"Docs site has no install dependencies\"",
  "buildCommand": "node docs-site/build.mjs",
  "outputDirectory": "docs-site/dist",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
