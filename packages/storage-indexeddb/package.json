{
  "name": "@offlinejs/storage-indexeddb",
  "version": "0.1.0",
  "description": "IndexedDB OfflineJS storage adapter for durable browser persistence.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@offlinejs/types": "workspace:*",
    "@offlinejs/utils": "workspace:*"
  },
  "devDependencies": {
    "tsup": "latest",
    "typescript": "latest"
  }
}
