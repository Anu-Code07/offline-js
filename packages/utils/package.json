{
  "name": "@offlinejs/utils",
  "version": "0.1.0",
  "description": "Small runtime utilities for OfflineJS packages.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@offlinejs/types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "latest",
    "typescript": "latest"
  }
}
