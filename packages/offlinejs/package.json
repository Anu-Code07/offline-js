{
  "name": "@offlinejs/client",
  "version": "0.1.3",
  "description": "One-import OfflineJS client SDK. Use specialized @offlinejs/* packages only when you need them.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@offlinejs/auth": "workspace:*",
    "@offlinejs/benchmarks": "workspace:*",
    "@offlinejs/conflicts": "workspace:*",
    "@offlinejs/core": "workspace:*",
    "@offlinejs/devtools": "workspace:*",
    "@offlinejs/devtools-ui": "workspace:*",
    "@offlinejs/encryption": "workspace:*",
    "@offlinejs/network": "workspace:*",
    "@offlinejs/next": "workspace:*",
    "@offlinejs/react": "workspace:*",
    "@offlinejs/storage-indexeddb": "workspace:*",
    "@offlinejs/storage-memory": "workspace:*",
    "@offlinejs/storage-opfs": "workspace:*",
    "@offlinejs/storage-sqlite": "workspace:*",
    "@offlinejs/sync-protocol": "workspace:*",
    "@offlinejs/types": "workspace:*",
    "@offlinejs/validation": "workspace:*",
    "@offlinejs/worker-sync": "workspace:*",
    "@offlinejs/broadcast": "workspace:*",
    "@offlinejs/sw": "workspace:*",
    "@offlinejs/http-cache": "workspace:*",
    "@offlinejs/media-queue": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "latest",
    "react": "latest",
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
