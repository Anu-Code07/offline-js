{
  "name": "offline-js",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --check .",
    "docs:demo": "node docs-site/demo/build.mjs",
    "docs:build": "pnpm docs:demo && node docs-site/build.cjs",
    "bench": "OFFLINEJS_WRITE_BENCH=1 vitest run packages/benchmarks/src/generate-report.test.ts --testTimeout=600000",
    "vercel-build": "test -f docs-site/out/index.html",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "latest",
    "@eslint/js": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "esbuild": "^0.25.0",
    "eslint": "latest",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.11.0",
    "prettier": "latest",
    "tsup": "latest",
    "typescript": "5.7.3",
    "typescript-eslint": "latest",
    "vitest": "latest"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.7.3"
    }
  }
}
